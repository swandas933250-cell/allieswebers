{
  "entities": {
    "request": {
      "title": "Website Request",
      "description": "A request for a new website created by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who made the request." },
        "userName": { "type": "string" },
        "userEmail": { "type": "string", "format": "email" },
        "mobile": { "type": "string" },
        "businessType": { "type": "string" },
        "aesthetic": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "in progress", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "businessType", "status", "createdAt"]
    },
    "contact": {
      "title": "Contact Submission",
      "description": "A message sent via the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "mobile": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "status", "createdAt"]
    },
    "booking": {
      "title": "Architect Booking",
      "description": "A scheduled session with an architect.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "mobile": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "date", "time", "status", "createdAt"]
    }
  },
  "firestore": {
    "/requests/{requestId}": {
      "schema": "request",
      "description": "Collection of website requests."
    },
    "/contacts/{contactId}": {
      "schema": "contact",
      "description": "Collection of contact form submissions."
    },
    "/bookings/{bookingId}": {
      "schema": "booking",
      "description": "Collection of architect bookings."
    }
  }
}
